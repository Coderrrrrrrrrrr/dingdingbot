# CloudBase AI Assistant Environment Variables
# Copy this file to .env and fill in your actual values

# Doubao (豆包) API Configuration
DOUBAO_API_KEY=your_doubao_api_key_here
DOUBAO_BASE_URL=https://
DOUBAO_MODEL=

# DingTalk App Configuration (Self-built App)
DINGTALK_CLIENT_ID=your_dingtalk_client_id_here
DINGTALK_CLIENT_SECRET=your_dingtalk_client_secret_here

# Output Directory for Generated Documents
OUTPUT_DIR=E:\

# DWS CLI Path (Optional)
DWS_PATH=C:\

# OA System Credentials (Optional, for automation)
OA_USERNAME=your_oa_username_here
OA_PASSWORD=your_oa_password_here
OA_URL=https://
